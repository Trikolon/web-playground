{
  "name": "web-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trikolon/web-playground.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "gen-certs": "mkdir -p certs && mkcert -cert-file certs/cert.pem -key-file certs/key.pem example.com \"*.example.com\" example.org \"*.example.org\" example.net \"*.example.net\" localhost 127.0.0.1 ::1",
    "prettier": "prettier --write ."
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@types/node": "^25.5.0",
    "dedent": "^1.7.2",
    "glob": "^13.0.6",
    "prettier": "^3.8.1",
    "vite": "^8.0.3",
    "wrangler": "^4.80.0"
  }
}
