{
  "name": "web-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trikolon/web-playground.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "gen-certs": "mkdir -p certs && mkcert -cert-file certs/cert.pem -key-file certs/key.pem example.com \"*.example.com\" example.org \"*.example.org\" example.net \"*.example.net\" localhost 127.0.0.1 ::1",
    "lint": "tsc && eslint src/ && prettier --check .",
    "lint:fix": "eslint src/ --fix && prettier --write ."
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "dedent": "^1.7.2",
    "eslint": "^10.6.0",
    "glob": "^13.0.6",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "wrangler": "^4.105.0"
  }
}
